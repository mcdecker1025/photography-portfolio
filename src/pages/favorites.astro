---
import PhotoGrid from '@components/PhotoGrid.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getFavoritePhotos } from '@lib/trips';

const favoritePhotos = await getFavoritePhotos();
---

<BaseLayout
  title="Favorites"
  description="A cross-trip edit of favorite travel photographs."
>
  <section class="section">
    <div class="section__inner">
      <p class="eyebrow">Favorite frames</p>
      <h1 class="page-title">The photographs that keep asking for another look.</h1>
      <p class="page-lede">
        These images are pulled from every trip where a photo is marked as a favorite in the CMS.
      </p>
    </div>
  </section>

  <section class="section section--tight">
    <div class="section__inner">
      <PhotoGrid photos={favoritePhotos} showTrip />
    </div>
  </section>
</BaseLayout>
