---
import PhotoGrid from '@components/PhotoGrid.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDateRange, getAdjacentTrips, getAllTripPhotos, getTrips, type Trip } from '@lib/trips';

export async function getStaticPaths() {
  const trips = await getTrips();
  return trips.map((trip) => ({
    params: { slug: trip.data.slug },
    props: { trip, trips },
  }));
}

interface Props {
  trip: Trip;
  trips: Trip[];
}

const { trip, trips } = Astro.props;
const allPhotos = getAllTripPhotos(trip);
const favoritePhotos = trip.data.photos.filter((photo) => photo.favorite);
const storyParagraphs = trip.data.story.split(/\n{2,}/).filter(Boolean);
const { previous, next } = getAdjacentTrips(trips, trip.data.slug);
---

<BaseLayout title={trip.data.title} description={trip.data.summary}>
  <section class="trip-hero" aria-label={`${trip.data.title} introduction`}>
    <img class="trip-hero__image" src={trip.data.heroImage} alt="" />
    <div class="trip-hero__content">
      <p class="eyebrow">{trip.data.location} · {formatDateRange(trip.data.dateStart, trip.data.dateEnd)}</p>
      <h1>{trip.data.title}</h1>
      <p>{trip.data.summary}</p>
    </div>
  </section>

  <section class="section">
    <div class="section__inner story">
      <aside class="story__details" aria-label="Trip details">
        <p><span>Location</span>{trip.data.location}</p>
        <p><span>Dates</span>{formatDateRange(trip.data.dateStart, trip.data.dateEnd)}</p>
        <p><span>Photos</span>{allPhotos.length} selected frames</p>
      </aside>
      <div class="story__copy">
        {storyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  {
    favoritePhotos.length > 0 && (
      <section class="section section--tight">
        <div class="section__inner">
          <p class="eyebrow">Favorites from this trip</p>
          <PhotoGrid photos={favoritePhotos} />
        </div>
      </section>
    )
  }

  <section class="section section--tight">
    <div class="section__inner">
      <p class="eyebrow">Full gallery</p>
      <PhotoGrid photos={allPhotos} />
    </div>
  </section>

  <section class="section section--tight">
    <nav class="section__inner trip-nav" aria-label="Adjacent trips">
      {previous && (
        <a href={`/trips/${previous.data.slug}/`}>
          <span>Previous trip</span>
          <strong>{previous.data.title}</strong>
        </a>
      )}
      {next && (
        <a href={`/trips/${next.data.slug}/`}>
          <span>Next trip</span>
          <strong>{next.data.title}</strong>
        </a>
      )}
    </nav>
  </section>
</BaseLayout>
