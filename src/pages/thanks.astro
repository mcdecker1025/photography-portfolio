---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Thanks" description="Thanks for contacting Matthew Decker Photography.">
  <section class="section">
    <div class="section__inner content-panel">
      <p class="eyebrow">Message sent</p>
      <h1 class="page-title">Thanks for reaching out.</h1>
      <p>Your note has been submitted. I’ll get back to you when I’m back at the desk.</p>
      <div class="inline-actions">
        <a class="button" href="/galleries/">Return to galleries</a>
      </div>
    </div>
  </section>
</BaseLayout>
