---
import type { Trip } from '@lib/trips';
import { formatDateRange } from '@lib/trips';

interface Props {
  trip: Trip;
  headingLevel?: 'h2' | 'h3';
}

const { trip, headingLevel = 'h2' } = Astro.props;
const Heading = headingLevel;
---

<a class="trip-card" href={`/trips/${trip.data.slug}/`}>
  <span class="trip-card__media">
    <img src={trip.data.coverImage} alt="" loading="lazy" />
  </span>
  <span class="trip-card__body">
    <span class="trip-card__meta">{trip.data.location} · {formatDateRange(trip.data.dateStart, trip.data.dateEnd)}</span>
    <Heading>{trip.data.title}</Heading>
    <p>{trip.data.summary}</p>
  </span>
</a>
