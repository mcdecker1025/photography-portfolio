---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/galleries/', label: 'Galleries' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

const isCurrent = (href: string) => {
  return href === '/galleries/' ? currentPath.startsWith('/galleries') : currentPath === href;
};
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="Photography portfolio home">
      <span class="brand__mark" aria-hidden="true">MD</span>
      <span class="brand__text">Matthew Decker Photography</span>
    </a>

    <nav class="nav" aria-label="Primary navigation">
      {
        links.map((link) => (
          <a href={link.href} aria-current={isCurrent(link.href) ? 'page' : undefined}>
            {link.label}
          </a>
        ))
      }
      <a href="/admin/">Admin</a>
    </nav>
  </div>
</header>
