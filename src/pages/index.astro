---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getGalleries, getGalleryHeroImage, getGalleryPhotos, getGallerySlug } from '@lib/galleries';

const galleries = await getGalleries();
const featuredGallery = galleries[0];
---

<BaseLayout>
  <section class="category-hero" aria-label="Photography gallery categories">
    <img
      class="category-hero__image"
      src={featuredGallery ? getGalleryHeroImage(featuredGallery) : '/uploads/trips/img_5265.jpeg'}
      alt=""
    />
    <div class="category-hero__content">
      <p class="category-hero__kicker">Matthew Decker Photography</p>
      <h1>Photography Galleries</h1>
      <nav class="category-menu" aria-label="Gallery categories">
        {
          galleries.map((gallery, index) => (
            <a href={`/galleries/${getGallerySlug(gallery)}/`}>
              <img src={gallery.data.coverImage} alt="" loading={index < 4 ? 'eager' : 'lazy'} />
              <span class="category-menu__label">
                <span>{gallery.data.title}</span>
                <small>{getGalleryPhotos(gallery).length} images</small>
              </span>
            </a>
          ))
        }
      </nav>
    </div>
  </section>
</BaseLayout>
