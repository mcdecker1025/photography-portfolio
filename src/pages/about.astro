---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getPageContent } from '@lib/pages';

const page = await getPageContent('about', {
  title: 'About',
  description: 'About Matthew Decker Photography and the photography portfolio.',
  eyebrow: 'About',
  heading: 'A personal archive for places, light, and memory.',
  paragraphs: [
    'This portfolio is set up as a living archive of gallery categories: mountaineering, landscapes, animals, architecture, night skies, aerial work, and any other collections that fit the photographs.',
    'The gallery structure can grow over time. Upload web-ready files through the CMS, add titles and descriptions, and publish when a category is ready to update.',
  ],
});
---

<BaseLayout
  title={page.title}
  description={page.description}
>
  <section class="section">
    <div class="section__inner content-panel">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1 class="page-title">{page.heading}</h1>
      {page.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <div class="inline-actions">
        <a class="button" href="/contact/">Get in touch</a>
        <a class="button button--ghost" href="/galleries/">Browse galleries</a>
      </div>
    </div>
  </section>
</BaseLayout>
