---
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDateRange, getAllTripPhotos, getTrips } from '@lib/trips';

const trips = await getTrips();
---

<BaseLayout>
  <section class="home-intro" aria-label="Portfolio introduction">
    <p class="eyebrow">Travel photography portfolio</p>
    <h1>Frames from the road, gathered by trip.</h1>
    <p>
      A personal archive of places, light, and favorite images. Scroll through the trips, then open each one for the full edit.
    </p>
  </section>

  <section class="trip-stack" aria-label="Trip archive">
    {
      trips.map((trip, index) => {
        const photoCount = getAllTripPhotos(trip).length;
        return (
          <a class="trip-panel" href={`/trips/${trip.data.slug}/`}>
            <img class="trip-panel__image" src={trip.data.coverImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
            <span class="trip-panel__content">
              <span class="trip-panel__meta">
                {trip.data.location} · {formatDateRange(trip.data.dateStart, trip.data.dateEnd)} · {photoCount} photos
              </span>
              <span class="trip-panel__title">{trip.data.title}</span>
              <span class="trip-panel__summary">{trip.data.summary}</span>
              <span class="trip-panel__cta">View trip</span>
            </span>
          </a>
        );
      })
    }
  </section>

  <section class="home-outro">
    <a class="button" href="/favorites/">View favorite frames</a>
    <a class="button button--ghost" href="/about/">About the archive</a>
  </section>
</BaseLayout>
