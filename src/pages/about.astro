---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Matthew Decker Photography and the travel portfolio."
>
  <section class="section">
    <div class="section__inner content-panel">
      <p class="eyebrow">About</p>
      <h1 class="page-title">A personal archive for places, light, and memory.</h1>
      <p>
        This portfolio is set up as a living travel archive: each trip gets a concise field note, a handful of favorites, and a gallery that can grow over time.
      </p>
      <p>
        The current images are polished placeholders so the site can be designed and deployed before the real curated exports are ready. Once you begin replacing them, the structure stays the same: upload web-ready files, add captions, mark favorites, and publish.
      </p>
      <div class="inline-actions">
        <a class="button" href="/contact/">Get in touch</a>
        <a class="button button--ghost" href="/trips/">Browse trips</a>
      </div>
    </div>
  </section>
</BaseLayout>
