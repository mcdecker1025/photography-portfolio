---
import type { DisplayPhoto } from '@lib/galleries';

interface Props {
  photos: DisplayPhoto[];
}

const { photos } = Astro.props;

const getTileClass = (photo: DisplayPhoto) => {
  if (photo.orientation === 'portrait') return 'photo-tile photo-tile--portrait';
  if (photo.orientation === 'square') return 'photo-tile photo-tile--square';
  return 'photo-tile photo-tile--wide';
};
---

<div class="photo-grid">
  {
    photos.map((photo) => (
      <figure class={getTileClass(photo)}>
        <button
          class="photo-button"
          type="button"
          data-gallery-image={photo.image}
          data-gallery-alt={photo.alt}
          data-gallery-title={photo.title}
          data-gallery-location={photo.location}
          data-gallery-description={photo.description}
          data-gallery-caption={`${photo.title} | ${photo.location}. ${photo.description}`}
          aria-label={`Open photo: ${photo.title}`}
        >
          <img src={photo.image} alt={photo.alt} loading="lazy" />
          <span class="photo-overlay" aria-hidden="true">
            <span class="photo-overlay__title">{photo.title} | {photo.location}</span>
            <span class="photo-overlay__description">{photo.description}</span>
          </span>
        </button>
        <figcaption class="photo-caption">
          {photo.title} | {photo.location}
        </figcaption>
      </figure>
    ))
  }
</div>
