---
import type { FavoritePhoto, TripPhoto } from '@lib/trips';

interface Props {
  photos: TripPhoto[] | FavoritePhoto[];
  showTrip?: boolean;
}

const { photos, showTrip = false } = Astro.props;

const getTileClass = (photo: TripPhoto | FavoritePhoto) => {
  if (photo.orientation === 'portrait') return 'photo-tile photo-tile--portrait';
  if (photo.orientation === 'square') return 'photo-tile photo-tile--square';
  return 'photo-tile photo-tile--wide';
};
---

<div class="photo-grid">
  {
    photos.map((photo) => (
      <figure class={getTileClass(photo)}>
        <button
          class="photo-button"
          type="button"
          data-gallery-image={photo.image}
          data-gallery-alt={photo.alt}
          data-gallery-caption={photo.caption}
          aria-label={`Open photo: ${photo.caption}`}
        >
          <img src={photo.image} alt={photo.alt} loading="lazy" />
        </button>
        <figcaption class="photo-caption">
          {photo.caption}
          {showTrip && 'tripTitle' in photo && (
            <>
              <br />
              <a class="favorite-link" href={`/trips/${photo.tripSlug}/`}>
                {photo.tripTitle} · {photo.tripLocation}
              </a>
            </>
          )}
        </figcaption>
      </figure>
    ))
  }
</div>
